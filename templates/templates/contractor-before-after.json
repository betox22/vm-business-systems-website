        "quote_form",
        "footer"
      ]
    },
    {
      "name": "Catalog",
      "purpose": "proof-based contractor portfolio",
      "catalogType": "project_gallery_catalog",
      "layout": "before-after slider, services, project gallery, estimate form",
      "filters": [
        "project_type",
        "room_area",
        "budget_range",
        "location"
      ]
    },
    {
      "name": "Detail",
      "purpose": "Product, service, offer, menu item, or project detail",
      "layout": "project detail with before/after, scope, materials, timeline, estimate CTA",
      "upsell": "inspection, premium materials, maintenance service"
    }
  ]
